---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const posts = await getCollection("essays", ({ id, data }) => {
  return id.startsWith("en/") && data.lang === "en";
});

posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="English Essays | Arash Derakhshan"
  description="English essays by Arash Derakhshan."
  lang="en"
  dir="ltr"
>
  <p><a href="/">← Home</a></p>

  <h1>English Essays</h1>

  <ul>
    {posts.map((post) => (
      <li>
        <a href={`/en/essays/${post.id.replace("en/", "")}/`}>
          {post.data.title}
        </a>
        {" "}
        <small>{post.data.pubDate.toLocaleDateString("en-US")}</small>
      </li>
    ))}
  </ul>
</BaseLayout>