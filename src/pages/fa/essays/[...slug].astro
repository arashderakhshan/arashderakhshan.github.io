---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("essays", ({ id, data }) => {
    return id.startsWith("fa/") && data.lang === "fa";
  });

  return posts.map((post) => ({
    params: {
      slug: post.id.replace("fa/", ""),
    },
    props: {
      post,
    },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout
  title={`${post.data.title} | آرش درخشان`}
  description={post.data.description}
  lang="fa"
  dir="rtl"
>
  <div class="essay-page rtl">


    <article>
      <header class="article-header">
        <p class="eyebrow">مقاله · آرش درخشان</p>

        <h1 class="article-title">
          {post.data.title}
        </h1>

        <p class="article-description">
          {post.data.description}
        </p>

        <div class="article-meta">
          <span>
            {post.data.pubDate.toLocaleDateString("fa-IR", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })}
          </span>

          <span class="article-meta-separator">·</span>

          <span>arashd.ir</span>
        </div>
      </header>

      <div class="article-divider"></div>

      <section class="article-body">
        <Content />
      </section>

      <footer class="article-footer">
        <p class="article-footer-label">
          پایان مقاله
        </p>

        <p>
          <a href="/fa/">
            مشاهده نوشته‌های بیشتر ←
          </a>
        </p>
      </footer>
    </article>
  </div>
</BaseLayout>