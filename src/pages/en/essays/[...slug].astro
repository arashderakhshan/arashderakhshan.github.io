---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("essays", ({ id, data }) => {
    return id.startsWith("en/") && data.lang === "en";
  });

  return posts.map((post) => ({
    params: {
      slug: post.id.replace("en/", ""),
    },
    props: {
      post,
    },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout
  title={`${post.data.title} | Arash Derakhshan`}
  description={post.data.description}
  lang="en"
  dir="ltr"
>
  <div class="essay-page">


    <article>
      <header class="article-header">
        <p class="eyebrow">ESSAY · ARASH DERAKHSHAN</p>

        <h1 class="article-title">
          {post.data.title}
        </h1>

        <p class="article-description">
          {post.data.description}
        </p>

        <div class="article-meta">
          <span>
            {post.data.pubDate.toLocaleDateString("en-US", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })}
          </span>

          <span class="article-meta-separator">·</span>

          <span>arashd.ir</span>
        </div>
      </header>

      <div class="article-divider"></div>

      <section class="article-body">
        <Content />
      </section>

      <footer class="article-footer">
        <p class="article-footer-label">
          END OF ESSAY
        </p>

        <p>
          <a href="/en/">
            ← Explore more essays
          </a>
        </p>
      </footer>
    </article>
  </div>
</BaseLayout>